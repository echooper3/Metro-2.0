rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (Phase 3)
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'admin@inside-the-metro.com' ||
              request.auth.token.email == 'donva.adkism@gmail.com' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints (Pillar 2)
    // ===============================================================

    function isValidUser(data) {
      return data.id is string && data.id == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 256 &&
             data.savedEvents is list && data.savedEvents.size() <= 100 &&
             data.preferences is map &&
             data.preferences.favoriteCategories is list &&
             (!('hasCompletedOnboarding' in data.preferences) || data.preferences.hasCompletedOnboarding is bool) &&
             (!('avatar' in data) || data.avatar is string) &&
             (!('phone' in data) || data.phone is string) &&
             (!('birthday' in data) || data.birthday is string) &&
             (!('zipCode' in data) || data.zipCode is string) &&
             (!('orgId' in data) || data.orgId is string) &&
             (!('orgRole' in data) || data.orgRole is string) &&
             (!('isOrganizer' in data) || data.isOrganizer is bool) &&
             (!('accountType' in data) || data.accountType is string) &&
             (!('role' in data) || data.role is string);
    }

    function isValidEvent(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 150 &&
             data.category is string &&
             data.description is string && data.description.size() <= 3000 &&
             data.cityName is string &&
             data.venue is string &&
             data.userId is string &&
             data.userCreated is bool &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('price' in data) || data.price is string) &&
             (!('organizerName' in data) || data.organizerName is string) &&
             (!('organizerUrl' in data) || data.organizerUrl is string) &&
             (!('organizerContact' in data) || data.organizerContact is string) &&
             (!('orgId' in data) || data.orgId is string);
    }

    function isValidOrganization(data) {
      return data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             (!('website' in data) || data.website is string) &&
             (!('email' in data) || data.email is string) &&
             (!('phone' in data) || data.phone is string) &&
             (!('logoUrl' in data) || data.logoUrl is string) &&
             data.ownerId is string && data.ownerId == request.auth.uid &&
             data.members is list && data.members.size() <= 100;
    }

    function isValidAd(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 150 &&
             data.tag is string && data.tag.size() <= 50 &&
             data.description is string && data.description.size() <= 1000 &&
             data.cta is string && data.cta.size() <= 50 &&
             data.image is string && data.image.size() <= 200000 &&
             data.url is string && data.url.size() <= 1000 &&
             data.cityId is string &&
             data.clicks is number && data.clicks >= 0 &&
             data.impressions is number && data.impressions >= 0;
    }

    function isValidSponsorship(data) {
      return data.id is string &&
             data.userId is string &&
             data.userEmail is string &&
             data.userName is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 150 &&
             data.tag is string && data.tag.size() <= 50 &&
             data.description is string && data.description.size() <= 1000 &&
             data.cta is string && data.cta.size() <= 50 &&
             data.image is string && data.image.size() <= 200000 &&
             data.url is string && data.url.size() <= 1000 &&
             data.cityId is string &&
             data.status is string && (data.status == 'pending' || data.status == 'approved' || data.status == 'declined');
    }


    // ===============================================================
    // Rules (Pillar 4)
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if isVerifiedUser() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming()) && 
                    incoming().keys().hasAll(['id', 'name', 'email', 'savedEvents', 'preferences']) &&
                    !('role' in incoming());

      allow update: if (isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) &&
                    // Action-Based Update: Profile synchronization
                    (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'phone', 'birthday', 'zipCode', 'savedEvents', 'preferences', 'syncStats', 'orgId', 'orgRole', 'isOrganizer', 'accountType'])) &&
                    !('role' in incoming())) 
                    || isAdmin();
    }

    match /events/{eventId} {
      allow read: if true; // Public directory
      
      // Pillar 8: Secure List Queries
      allow list: if true; 

      allow create: if isVerifiedUser() && isValidId(eventId) &&
                    isValidEvent(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    incoming().userCreated == true &&
                    incoming().createdAt == request.time;
      
      allow update: if (isSignedIn() && existing().userId == request.auth.uid &&
                    isValidEvent(incoming()) &&
                    incoming().userId == existing().userId &&
                    // Action: Content Edit
                    incoming().diff(existing()).affectedKeys().hasAll(['updatedAt']) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'date', 'time', 'venue', 'location', 'imageUrl', 'price', 'ageRestriction', 'updatedAt', 'organizerName', 'organizerUrl', 'organizerContact', 'orgId']) &&
                    incoming().updatedAt == request.time)
                    || isAdmin();

      allow delete: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isVerifiedUser() && isValidId(orgId) &&
                    isValidOrganization(incoming()) &&
                    incoming().ownerId == request.auth.uid &&
                    incoming().id == orgId;
      allow update: if isSignedIn() && isValidOrganization(incoming()) &&
                    (existing().ownerId == request.auth.uid || 
                     incoming().diff(existing()).affectedKeys().hasOnly(['members']));
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /stats/{statId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidId(statId) && statId == 'traffic';
      allow update: if isSignedIn() && isValidId(statId) && statId == 'traffic' &&
                    incoming().diff(existing()).affectedKeys().hasAny(['totalViews', 'cityViews', 'eventViews', 'categoryViews', 'searchQueries', 'eventSaves', 'lastUpdated']) &&
                    incoming().lastUpdated == request.time;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(adId) && isValidAd(incoming());
      allow update: if (incoming().diff(existing()).affectedKeys().hasOnly(['clicks', 'impressions']) &&
                        incoming().clicks >= existing().clicks &&
                        incoming().impressions >= existing().impressions)
                    || (isAdmin() && isValidAd(incoming()));
      allow delete: if isAdmin();
    }

    match /sponsorships/{sponsorshipId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isSignedIn() && isValidId(sponsorshipId) &&
                    isValidSponsorship(incoming()) &&
                    incoming().id == sponsorshipId &&
                    incoming().userId == request.auth.uid &&
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time;
      allow update: if (isSignedIn() && request.auth.uid == existing().userId &&
                    isValidSponsorship(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().status == 'pending' &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'tag', 'cta', 'image', 'url', 'cityId', 'updatedAt']) &&
                    (!('updatedAt' in incoming()) || incoming().updatedAt == request.time))
                    || isAdmin();
      allow delete: if (isSignedIn() && existing().userId == request.auth.uid && existing().status == 'pending')
                    || isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
