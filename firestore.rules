rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (Phase 3)
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "donva.adkism@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints (Pillar 2)
    // ===============================================================

    function isValidUser(data) {
      return data.id is string && data.id == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 256 &&
             data.savedEvents is list && data.savedEvents.size() <= 100 &&
             data.preferences is map &&
             data.preferences.favoriteCategories is list &&
             (!('hasCompletedOnboarding' in data.preferences) || data.preferences.hasCompletedOnboarding is bool) &&
             (!('avatar' in data) || data.avatar is string) &&
             (!('phone' in data) || data.phone is string) &&
             (!('birthday' in data) || data.birthday is string) &&
             (!('zipCode' in data) || data.zipCode is string);
    }

    function isValidEvent(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 150 &&
             data.category is string &&
             data.description is string && data.description.size() <= 3000 &&
             data.cityName is string &&
             data.venue is string &&
             data.userId is string &&
             data.userCreated is bool &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('price' in data) || data.price is string);
    }

    // ===============================================================
    // Rules (Pillar 4)
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if isVerifiedUser() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming()) && 
                    incoming().keys().hasAll(['id', 'name', 'email', 'savedEvents', 'preferences']) &&
                    !('role' in incoming());

      allow update: if (isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) &&
                    // Action-Based Update: Profile synchronization
                    (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'phone', 'birthday', 'zipCode', 'savedEvents', 'preferences', 'syncStats'])) &&
                    !('role' in incoming())) 
                    || isAdmin();
    }

    match /events/{eventId} {
      allow read: if true; // Public directory
      
      // Pillar 8: Secure List Queries
      allow list: if true; 

      allow create: if isVerifiedUser() && isValidId(eventId) &&
                    isValidEvent(incoming()) &&
                    incoming().userId == request.auth.uid &&
                    incoming().userCreated == true &&
                    incoming().createdAt == request.time;
      
      allow update: if (isSignedIn() && existing().userId == request.auth.uid &&
                    isValidEvent(incoming()) &&
                    incoming().userId == existing().userId &&
                    // Action: Content Edit
                    incoming().diff(existing()).affectedKeys().hasAll(['updatedAt']) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'date', 'time', 'venue', 'location', 'imageUrl', 'price', 'ageRestriction', 'updatedAt']) &&
                    incoming().updatedAt == request.time)
                    || isAdmin();

      allow delete: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
    }

    match /stats/{statId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidId(statId) && statId == 'traffic';
      allow update: if isSignedIn() && isValidId(statId) && statId == 'traffic' &&
                    incoming().diff(existing()).affectedKeys().hasAny(['totalViews', 'cityViews', 'eventViews', 'categoryViews', 'searchQueries', 'eventSaves', 'lastUpdated']) &&
                    incoming().lastUpdated == request.time;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
